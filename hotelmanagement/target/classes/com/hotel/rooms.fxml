<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.RoomController">
    <top>
        <GridPane hgap="10" vgap="10" padding="10">
            <children>
                <Label text="Room Number:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="roomNumberField" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                <Label text="Room Type:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <ComboBox fx:id="roomTypeCombo" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="Price:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="priceField" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                <Button fx:id="addButton" text="Add Room" onAction="#handleAddRoom" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <Button fx:id="updateButton" text="Update Room" onAction="#handleUpdateRoom" GridPane.rowIndex="3" GridPane.columnIndex="1" />
            </children>
        </GridPane>
    </top>
    <center>
        <TableView fx:id="roomsTable" prefHeight="300" prefWidth="400">
            <columns>
                <TableColumn fx:id="colNumber" text="Room Number" />
                <TableColumn fx:id="colType" text="Type" />
                <TableColumn fx:id="colPrice" text="Price" />
                <TableColumn fx:id="colStatus" text="Status" />
            </columns>
        </TableView>
    </center>
</BorderPane>
