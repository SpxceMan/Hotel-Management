<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.CustomerController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <top>
        <VBox spacing="16">
            <children>
                <!-- Header row -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <children>
                        <Label text="Customers" styleClass="view-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="countLabel" styleClass="customer-badge"/>
                    </children>
                </HBox>

                <!-- Search + Add panel -->
                <HBox styleClass="form-panel" spacing="10" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Search:"/>
                        <TextField fx:id="searchField" promptText="Search by name…" prefWidth="200"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Add Customer:"/>
                        <TextField fx:id="addNameField" promptText="Customer name" prefWidth="180"/>
                        <Button text="Add" onAction="#handleAdd" styleClass="btn-primary"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="16"/>
            </padding>
            <children>
                <TableView fx:id="customersTable" VBox.vgrow="ALWAYS" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="colIndex" text="#" prefWidth="50"/>
                        <TableColumn fx:id="colName" text="Customer Name" prefWidth="250"/>
                        <TableColumn fx:id="colBookings" text="Active Bookings" prefWidth="160"/>
                        <TableColumn fx:id="colTotal" text="Total Spent" prefWidth="140"/>
                    </columns>
                </TableView>

                <!-- Bottom action row -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <children>
                        <Button text="Remove Selected" onAction="#handleRemove" styleClass="btn-danger"/>
                        <Label fx:id="messageLabel" styleClass="message-label"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
