<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.RoomController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <top>
        <VBox spacing="16">
            <children>
                <Label text="Rooms" styleClass="view-title"/>

                <HBox styleClass="form-panel" spacing="12" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Room No:"/>
                        <TextField fx:id="roomNumberField" promptText="e.g. 101" prefWidth="90"/>
                        <Label text="Type:"/>
                        <ComboBox fx:id="roomTypeCombo" prefWidth="120"/>
                        <Label text="Price/night:"/>
                        <TextField fx:id="priceField" promptText="e.g. 99.00" prefWidth="100"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="addButton"    text="Add Room"    onAction="#handleAddRoom"    styleClass="btn-primary"/>
                        <Button fx:id="updateButton" text="Update Room" onAction="#handleUpdateRoom" styleClass="btn-secondary"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="0">
            <padding>
                <Insets top="16"/>
            </padding>
            <children>
                <TableView fx:id="roomsTable" prefHeight="350" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNumber" text="Room #"  prefWidth="90"/>
                        <TableColumn fx:id="colType"   text="Type"    prefWidth="130"/>
                        <TableColumn fx:id="colPrice"  text="Price/Night" prefWidth="130"/>
                        <TableColumn fx:id="colStatus" text="Status"  prefWidth="120"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
</BorderPane>
