<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.DashboardController">
    <left>
        <VBox fx:id="sidebar" spacing="8.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <Button text="Dashboard" onAction="#handleDashboard" />
                <Button text="Rooms" onAction="#handleRooms" />
                <Button text="Bookings" onAction="#handleBookings" />
                <Button text="Customers" onAction="#handleCustomers" />
                <Button text="Logout" onAction="#handleLogout" />
            </children>
            <padding>
                <Insets top="12.0" right="8.0" bottom="12.0" left="8.0" />
            </padding>
        </VBox>
    </left>
    <top>
        <HBox spacing="10.0" styleClass="topbar" BorderPane.alignment="CENTER">
            <children>
                <Label text="Hotel Management System" style="-fx-font-size:16px; -fx-font-weight:bold;" />
                <Label text="" HBox.hgrow="ALWAYS" />
                <Label text="Welcome, Admin" />
            </children>
            <padding>
                <Insets top="10.0" right="12.0" bottom="10.0" left="12.0" />
            </padding>
        </HBox>
    </top>
    <center>
        <StackPane fx:id="centerPane" />
    </center>
</BorderPane>
