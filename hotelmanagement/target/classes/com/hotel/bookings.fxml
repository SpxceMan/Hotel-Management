<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.BookingController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <top>
        <VBox spacing="16">
            <children>
                <Label text="Bookings" styleClass="view-title"/>

                <HBox styleClass="form-panel" spacing="10" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Room:"/>
                        <ComboBox fx:id="roomSelect" prefWidth="150"/>
                        <Label text="Customer:"/>
                        <TextField fx:id="customerField" promptText="Full name" prefWidth="140"/>
                        <Label text="Check-in:"/>
                        <DatePicker fx:id="checkinPicker" prefWidth="140"/>
                        <Label text="Check-out:"/>
                        <DatePicker fx:id="checkoutPicker" prefWidth="140"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Book" onAction="#handleBook" styleClass="btn-primary"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="16"/>
            </padding>
            <children>
                <TableView fx:id="bookingsTable" prefHeight="300" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colRoom"     text="Room"       prefWidth="80"/>
                        <TableColumn fx:id="colCustomer" text="Customer"   prefWidth="180"/>
                        <TableColumn fx:id="colCheckIn"  text="Check-In"   prefWidth="120"/>
                        <TableColumn fx:id="colCheckOut" text="Check-Out"  prefWidth="120"/>
                        <TableColumn fx:id="colTotal"    text="Total ($)"  prefWidth="110"/>
                    </columns>
                </TableView>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <children>
                        <Button text="Checkout Selected" onAction="#handleCheckout" styleClass="btn-danger"/>
                        <Label fx:id="messageLabel" styleClass="message-label"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
