<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>

<GridPane hgap="10.0" vgap="10.0" alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.SecondaryController">
    <children>
        <Label text="Room Number:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="roomNumberField" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Room Type:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <ComboBox fx:id="roomTypeCombo" GridPane.rowIndex="1" GridPane.columnIndex="1" />

        <Label text="Price:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <TextField fx:id="priceField" GridPane.rowIndex="2" GridPane.columnIndex="1" />

        <Button text="Add Room" onAction="#handleAddRoom" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <Button text="Back" onAction="#switchToPrimary" GridPane.rowIndex="3" GridPane.columnIndex="1" />
    </children>
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>
</GridPane>
